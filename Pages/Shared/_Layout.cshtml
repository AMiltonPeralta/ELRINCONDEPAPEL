<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - El Rincón del Papel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom mb-4">
            <div class="container">
                <a class="navbar-brand navbar-brand-custom" asp-page="/Index">El Rincón del Papel</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-page="/Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-page="/Clientes">Clientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-page="/Productos">Productos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-page="/Proveedores">Proveedores</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-page="/Compras">Compras</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom" asp-page="/Ventas">Ventas</a>
                        </li>
                    </ul>
                    <div class="d-flex">
                        <a class="nav-link nav-link-custom nav-link-login px-3 py-2 text-white" asp-page="/Login">Ingresar</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom text-muted mt-5">
        <div class="container text-center">
            &copy; 2026 - <span class="text-white">El Rincón del Papel</span> - <a asp-page="/Index" class="text-decoration-none text-muted">Inicio</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
