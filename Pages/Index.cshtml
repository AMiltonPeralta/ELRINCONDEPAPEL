@page
@model IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<div class="card-custom text-center py-5">
    <span class="badge rounded-pill bg-primary px-3 py-2 mb-3 text-uppercase font-monospace" style="font-size: 0.8rem; letter-spacing: 2px;">Etapa 1 - Maquetación y SQL</span>
    <h1 class="display-3 mb-3 fw-extrabold text-white" style="font-family: var(--font-title);">El Rincón del Papel</h1>
    <p class="lead text-muted fs-4 mb-4 mx-auto" style="max-width: 600px;">
        Sistema de Gestión Comercial para Librería Multiproposito, Tecnología, Juegos y Accesorios.
    </p>
    <hr class="my-4 mx-auto style-five" style="max-width: 300px; border-top: 1px solid var(--border-glass);">
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a asp-page="/Clientes" class="btn btn-accent d-flex align-items-center gap-2">
            <span>Ver Clientes (SQL)</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
            </svg>
        </a>
        <a asp-page="/Login" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 10px; border-color: var(--border-glass); color: var(--text-primary);">
            Ingresar al Sistema
        </a>
    </div>
</div>

<div class="row mt-4 g-4">
    <div class="col-md-4">
        <div class="card-custom h-100 mt-0 py-4 px-4 text-center">
            <h3 class="text-white mb-2">📦 Catálogo</h3>
            <p class="text-muted">Organización de productos por rubro, marca y control automático de stock.</p>
            <a asp-page="/Productos" class="text-primary text-decoration-none fw-semibold">Explorar Productos &rarr;</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-custom h-100 mt-0 py-4 px-4 text-center">
            <h3 class="text-white mb-2">💸 Ventas y Compras</h3>
            <p class="text-muted">Registro de facturación electrónica y reposición de mercadería con proveedores.</p>
            <div class="d-flex justify-content-center gap-3">
                <a asp-page="/Ventas" class="text-primary text-decoration-none fw-semibold">Ventas</a>
                <span class="text-muted">|</span>
                <a asp-page="/Compras" class="text-primary text-decoration-none fw-semibold">Compras</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card-custom h-100 mt-0 py-4 px-4 text-center">
            <h3 class="text-white mb-2">🔌 Conexión SQL</h3>
            <p class="text-muted">Lectura en tiempo real de entidades almacenadas en tu servidor de base de datos local.</p>
            <a asp-page="/Clientes" class="text-primary text-decoration-none fw-semibold">Probar Lectura SQL &rarr;</a>
        </div>
    </div>
</div>
