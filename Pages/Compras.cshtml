@page
@{
    ViewData["Title"] = "Compras";
}

<div class="card-custom mt-0 text-center py-5">
    <div class="mb-4 text-primary fs-1">🚚</div>
    <h1 class="text-white mb-2">Registro de Compras</h1>
    <p class="text-muted fs-5 mb-4 mx-auto" style="max-width: 500px;">
        Esta pantalla permitirá registrar las compras a los proveedores, incrementando automáticamente el stock y actualizando el costo de compra.
    </p>
    <div class="bg-dark bg-opacity-25 rounded p-3 mb-4 mx-auto font-monospace text-start" style="max-width: 450px; font-size: 0.9rem;">
        <span class="text-info">// Acciones contempladas en el plan:</span><br>
        - Seleccionar proveedor y agregar múltiples productos.<br>
        - Registrar el precio de compra unitario.<br>
        - Actualizar el costo histórico en SQL Server.
    </div>
    <a asp-page="/Index" class="btn btn-accent">Volver al Inicio</a>
</div>
