@page
@model NegocioWeb.Pages.LoginModel
@{
    ViewData["Title"] = "Ingresar";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card-custom">
            <div class="text-center mb-4">
                <span class="fs-1">🔑</span>
                <h2 class="text-white mt-2 mb-1" style="font-family: var(--font-title);">Iniciar Sesión</h2>
                <p class="text-muted">El Rincón del Papel - Gestión Comercial</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.MensajeError))
            {
                <div class="alert alert-danger bg-danger bg-opacity-10 border-0 text-danger mb-3 p-3 rounded" role="alert" style="font-size: 0.9rem;">
                    <strong>Atención:</strong> @Model.MensajeError
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label for="Usuario" class="form-label text-muted font-monospace" style="font-size: 0.85rem;">USUARIO</label>
                    <input type="text" class="form-control form-control-custom" id="Usuario" name="Usuario" value="@Model.Usuario" placeholder="admin / vendedor" required />
                </div>
                <div class="mb-4">
                    <label for="Contrasena" class="form-label text-muted font-monospace" style="font-size: 0.85rem;">CONTRASEÑA</label>
                    <input type="password" class="form-control form-control-custom" id="Contrasena" name="Contrasena" placeholder="••••••••" required />
                </div>
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-accent py-2.5">Ingresar al Sistema</button>
                </div>
            </form>

            <div class="mt-4 text-center border-top border-secondary pt-3 bg-dark bg-opacity-10 rounded">
                <small class="text-muted d-block mb-1">Usuarios de prueba:</small>
                <div class="d-flex justify-content-around text-muted font-monospace" style="font-size: 0.8rem;">
                    <div><code>admin</code> / <code>admin123</code></div>
                    <div><code>vendedor</code> / <code>vendedor123</code></div>
                </div>
            </div>
        </div>
    </div>
</div>
